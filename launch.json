{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Nexus AI",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "console": "integratedTerminal",
      "env": {
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      },
      "envFile": "${workspaceFolder}/.env",
      "jinja": true
    }
  ]
}
